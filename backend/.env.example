APP_NAME=StudyFlow API
ENVIRONMENT=development

FRONTEND_URL=http://localhost:5173
# Use FRONTEND_URLS when you need more than one allowed frontend origin.
# Example: FRONTEND_URLS=http://localhost:5173,https://studyflowpro.vercel.app

DATABASE_URL=postgresql+psycopg2://studyflow_user:studyflow_password@localhost:5432/studyflow_db

MONGO_URL=mongodb://studyflow_mongo:studyflow_password@localhost:27017/studyflow_mongo?authSource=admin
MONGO_DB_NAME=studyflow_mongo

SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
